{
  "name": "rubin-browser",
  "version": "0.1.0",
  "description": "Browser for Vera Rubin Observatory public data — images, catalogs, time series, and galaxy analysis",
  "main": "src/index.ts",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:regression": "vitest run tests/regression",
    "test:ui": "playwright test",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}' 'tests/**/*.ts'",
    "docs:build": "typedoc"
  },
  "keywords": [
    "rubin",
    "lsst",
    "astronomy",
    "data-browser",
    "observatory"
  ],
  "author": "Peter Milford <pmilford@parallel-rules.com>",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/svelte": "^5.2.0",
    "@types/node": "^22.0.0",
    "@types/openseadragon": "^5.0.2",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.4.0",
    "typedoc": "^0.27.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "aladin-lite": "^3.6.0",
    "d3": "^7.9.0",
    "openseadragon": "^6.0.2",
    "svelte": "^5.0.0",
    "svelte-routing": "^2.0.0"
  }
}
